#!/bin/bash
if [ $# -lt 1 ]; then
    echo "Usage: cp2bin <file>"
    exit 1
fi

src="$1"

if [ ! -f "$src" ]; then
    echo "Error: file not found: $src"
    exit 1
fi

dest="/usr/local/bin/$(basename "$src")"

if [ -e "$dest" ]; then
    echo "Warning: $dest already exists and will be overwritten."
fi

if cp "$src" "$dest"; then
    chmod +x "$dest"
    echo "Installed to $dest"
else
    echo "Error: failed to copy. Maybe you need sudo?"
    exit 1
fi

